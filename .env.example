# Copia este archivo a ".env" y ajusta los valores. NUNCA subas ".env" al repositorio.

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=cambia_esta_password
DB_NAME=officespace_db

# Secreto de firma del JWT (genera uno largo y aleatorio, p. ej. `openssl rand -hex 32`)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_TTL=86400

# Orígenes permitidos para CORS (separados por comas)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
